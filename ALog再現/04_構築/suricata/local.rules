# ALog再現 east-west カスタムルール（決定論的検知。42_ndr_flowのthresholdルールを踏襲）
# HOME_NET = 172.41.0.0/24（alog-lan）。scanner→logsrc の横方向スキャンを確実に発報し、
# eve.json 経由でLokiに集約することで「ALog以外のログソース（NW機器/センサー系）」の
# 多様性を補完する（syslog経由のVector集約と対をなす2系統目のログ源）。

# SYNスキャン検知: 10秒間に同一送信元から15回以上のSYN(flags:S)で発報
alert tcp any any -> $HOME_NET any (msg:"ALog-Repro east-west SYN scan"; flags:S; threshold:type both,track by_src,count 15,seconds 10; classtype:attempted-recon; sid:2000001; rev:1;)

# 補助: logsrc宛の通信を台帳として記録（east-west通信の可視化補助）
alert tcp $HOME_NET any -> $HOME_NET any (msg:"ALog-Repro east-west traffic to logsrc"; flow:to_server; classtype:not-suspicious; sid:2000002; rev:1;)
