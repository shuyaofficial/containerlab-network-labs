#!/usr/bin/expect -f
# ACL マッチカウンタ採取用の検証 expect（設定投入なし・show のみ）。
set timeout 30
set node [lindex $argv 0]
log_file -noappend /Users/shuya/Documents/claude/Mac仮想環境構築/microseg_nftables/04_構築/out_verify.log
spawn sudo docker attach --sig-proxy=false $node
send "\r"
expect -re {[>#]}
send "enable\r"
expect "#"
send "terminal length 0\r"
expect "#"
send "show ip access-lists SEG10-OUT\r"
expect "#"
send "show ip interface brief\r"
expect "#"
send "\020\021"
expect eof
