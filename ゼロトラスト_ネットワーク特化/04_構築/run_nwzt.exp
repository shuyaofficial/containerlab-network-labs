#!/usr/bin/expect -f
# 統合コアSWへの設定投入: 1回のattachで投入→確認まで完結。出力を out.log に保存。
# 使い方: sudo expect run_nwzt.exp <node> <cfg>
set timeout 60
set node [lindex $argv 0]
set cfg   [lindex $argv 1]
log_file -noappend /Users/shuya/Documents/claude/Mac仮想環境構築/ゼロトラスト_ネットワーク特化/04_構築/out.log
spawn sudo docker attach --sig-proxy=false $node
send "\r"
expect {
  "initial configuration dialog" { send "no\r"; exp_continue }
  -re {[>#]} {}
  timeout {}
}
send "\r"
expect -re {[>#]}
send "enable\r"
expect "#"
send "terminal length 0\r"
expect "#"
send "configure terminal\r"
expect -re {\(config\)}
set fp [open $cfg r]
foreach line [split [read $fp] "\n"] {
    if {[string trim $line] eq ""} { continue }
    if {[string match "!*" $line]} { continue }
    send "$line\r"
    expect -re {[#>]}
}
close $fp
send "\r"
expect "#"
send "end\r"
expect "#"
send "write memory\r"
expect "#"
send "show authentication sessions\r"
expect "#"
send "show ip interface brief | include Vlan\r"
expect "#"
send "\020\021"
expect eof
