flowchart TB
    subgraph Untrust["Untrust（外部/ISP）"]
        direction TB
        ISP["isp\nAS 65100"]
    end

    subgraph DMZ["DMZ（公開サーバ収容）"]
        direction TB
        DMZSW["{{TOPO_NAME}}-dmz"]
        SRV["{{TOPO_NAME}}-dmz-srv"]
