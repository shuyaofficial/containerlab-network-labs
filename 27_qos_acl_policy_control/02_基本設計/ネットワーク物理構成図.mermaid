
graph TD
    %% Nodes
    core[hq-core\nL3 Switch]
    dist[hq-dist\nL3 Switch]
    edge[hq-edge\nRouter/NAT/QoS]
    dmz[hq-dmz\nL3 Switch]
    br_core[br-core\nL3 Switch]
    br_edge[br-edge\nRouter]
    isp_r[isp\nRouter]
    
    hq_pc[hq-pc\nData Endpoint]
    hq_voip[hq-voip\nVoice Endpoint]
    br_pc[br-pc\nData Endpoint]
    dmz_s[dmz-srv\nWeb Server]

    %% Links - HQ Internal
    core <-->|eth1 / eth1\n10.27.1.0/30| dist
    core <-->|eth2 / eth1\n10.27.1.4/30| edge
    core <-->|eth3 / eth1\n10.27.1.8/30| dmz
    
    %% Links - Endpoints HQ
    dist <-->|eth2 / eth1\n10.27.10.0/24| hq_pc
    dist <-->|eth3 / eth1\n10.27.50.0/24| hq_voip
    dmz <-->|eth2 / eth1\n10.27.30.0/24| dmz_s

    %% Links - WAN / ISP
    edge <-->|eth2 / eth1\n198.51.100.8/30| isp_r
    isp_r <-->|eth2 / eth1\n198.51.100.12/30| br_edge
    
    %% Links - Branch Internal
    br_edge <-->|eth2 / eth1\n10.27.2.0/30| br_core
    br_core <-->|eth2 / eth1\n10.27.20.0/24| br_pc

    %% Zones
    classDef trust fill:#d4edda,stroke:#28a745,stroke-width:2px,color:#000
    classDef untrust fill:#f8d7da,stroke:#dc3545,stroke-width:2px,color:#000
    classDef dmz_zone fill:#fff3cd,stroke:#ffc107,stroke-width:2px,color:#000
    classDef wan fill:#cce5ff,stroke:#007bff,stroke-width:2px,color:#000
    
    class core,dist,hq_pc,hq_voip,br_core,br_pc trust
    class edge,isp_r untrust
    class dmz,dmz_s dmz_zone
    class br_edge wan
