#!/usr/bin/expect -f
# 1回のattachで設定投入→確認まで完結。全出力を out.log に保存。
set timeout 40
set node [lindex $argv 0]
set cfg   [lindex $argv 1]
log_file -noappend /Users/shuya/Documents/claude/Mac仮想環境構築/31_nac_dot1x/04_構築/out.log
spawn sudo docker attach --sig-proxy=false $node
send "\r"
expect {
  "initial configuration dialog" { send "no\r"; exp_continue }
  -re {[>#]} {}
  timeout {}
}
send "\r"
expect -re {[>#]}
send "enable\r"
expect "#"
send "terminal length 0\r"
expect "#"
send "configure terminal\r"
expect -re {\(config\)}
set fp [open $cfg r]
foreach line [split [read $fp] "\n"] {
    if {[string trim $line] eq ""} { continue }
    if {[string match "!*" $line]} { continue }
    send "$line\r"
    expect -re {[#>]}
}
close $fp
send "\r"
expect "#"
send "end\r"
expect "#"
send "write memory\r"
expect "#"
send "show authentication sessions\r"
expect "#"
send "show dot1x all summary\r"
expect "#"
send "show vlan brief | include 10|99|Et0\r"
expect "#"
send "\020\021"
expect eof
